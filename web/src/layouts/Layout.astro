---
import '../styles/global.css';
import { LOCALES, i18n } from '../lib/data.js';

const { locale, relPath = '', active = '', title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');   // 確保結尾有 /
// Google Analytics 4：建好資源後把下面換成你的 Measurement ID（G- 開頭）。
// 只在 production build（pnpm build）載入，本機 dev 不送資料。
const GA_ID = 'G-DNK1GL5F3Q';
const T = i18n[locale];
const cur = LOCALES.find((l) => l.code === locale);

const url = (dir, rp) => base + dir + (rp ? rp + '/' : '');
const langUrls = Object.fromEntries(LOCALES.map((l) => [l.code, url(l.dir, relPath)]));
const page = url(cur.dir, '');                    // 當前語系根，給前端組個體連結

const nav = [
  ['', T.nav_home],
  ['pandas', T.nav_search],
  ['zoos', T.nav_zoos],
];
---
<!doctype html>
<html lang={cur.htmlLang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {import.meta.env.PROD && GA_ID && !GA_ID.includes('XXXX') && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </>
  )}
  <script is:inline>document.documentElement.classList.add('js');</script>
  <title>{title ? `${title} | ${T.site_title}` : T.site_title}</title>
  <meta name="theme-color" content="#b5552d" />
  <link rel="icon" href={`${base}icon.svg`} type="image/svg+xml" />
  <link rel="preload" as="font" type="font/woff2" href={`${base}fonts/fredoka-latin.woff2`} crossorigin />
  <script is:inline define:vars={{ base, locale, page, T,
    locales: LOCALES.map((l) => ({ code: l.code, dir: l.dir, label: l.label })), langUrls }}>
    window.BASE = base; window.LOCALE = locale; window.PAGE = page;
    window.T = T; window.LOCALES = locales; window.LANG_URLS = langUrls;
  </script>
  <script is:inline src={`${base}js/lang.js`}></script>
  <script is:inline src={`${base}js/theme.js`}></script>
  <script is:inline src={`${base}js/nav.js`}></script>
  <slot name="head" />
</head>
<body class:list={['font-sans', active === 'home' && 'home']}>
  <!-- 柔和天空（固定層，全站；裝飾用，輔助技術忽略）-->
  <div class="forest-bg" aria-hidden="true">
    <div class="sky"></div>
  </div>

  <header class="site-header" id="site-header">
    <div class="max-w-4xl mx-auto px-4 py-2.5 sm:py-3 flex items-center gap-x-2 gap-y-1.5 flex-wrap sm:flex-nowrap">
      <a href={page} class="brand order-1 font-display font-semibold text-lg sm:text-xl no-underline flex items-center gap-2 tracking-wide">
        <img src={`${base}icon.svg`} alt="" width="29" height="30" class="anim-bob inline-block" /> {T.site_title}
      </a>
      <div class="order-2 sm:order-3 ml-auto flex items-center gap-1">
        <button id="theme-toggle" type="button" aria-label="切換深色模式"
          class="nav-link inline-flex items-center justify-center leading-none bg-transparent border-0 cursor-pointer p-2 rounded-full">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <!-- 語言切換：只顯示地球 icon（隱藏文字），省空間避免手機版 header 換行。
             icon 用 inline SVG + currentColor，跟夜間切換、漢堡選單同樣線條風格、會跟著深色模式變色 -->
        <span class="nav-link relative inline-flex items-center justify-center rounded-full" style="width:38px;height:34px;">
          <svg aria-hidden="true" class="pointer-events-none text-ink-soft" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/><path d="M3 12h18"/>
            <path d="M12 3c2.7 2.9 2.7 15.1 0 18"/><path d="M12 3c-2.7 2.9-2.7 15.1 0 18"/>
          </svg>
          <select id="lang-select" aria-label="Language" title="Language"
            class="absolute inset-0 w-full h-full bg-transparent border-0 cursor-pointer appearance-none"
            style="color:transparent;opacity:0">
            {LOCALES.map((l) => <option value={l.code} selected={l.code === locale} style="color:var(--ink)">{l.label}</option>)}
          </select>
        </span>
        <button id="nav-toggle" type="button" aria-label={T.nav_menu ?? '選單'} aria-expanded="false" aria-controls="site-nav"
          class="nav-link sm:hidden inline-flex items-center justify-center leading-none bg-transparent border-0 cursor-pointer p-2 rounded-full">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </button>
      </div>
      <nav id="site-nav" class="order-3 sm:order-2 w-full sm:w-auto sm:ml-auto hidden sm:flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-1">
        {nav.map(([rp, label]) => (
          <a href={url(cur.dir, rp)}
             class={`nav-link px-3.5 py-1.5 rounded-full text-[.92rem] text-center sm:text-left whitespace-nowrap no-underline ${active === (rp || 'home') ? 'active' : ''}`}>{label}</a>
        ))}
      </nav>
    </div>
  </header>

  <div class:list={['max-w-4xl mx-auto px-4 pb-16', active !== 'home' && 'pt-[60px] sm:pt-[68px]']}>
    <slot />
    <footer class="mt-12 card-soft text-ink-soft text-[.84rem] px-4 py-3 text-center">
      <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-1">
        <a href={url(cur.dir, 'feedback')} class="text-rust no-underline hover:underline">🐾 {T.feedback_footer_link}</a>
        <span aria-hidden="true" class="hidden sm:inline opacity-40">·</span>
        <a href={url(cur.dir, 'thanks')} class="text-rust no-underline hover:underline">{T.thanks_footer_link}</a>
      </div>
      <div class="mt-1.5">{T.footer_note}・{T.data_note} {new Date().toISOString().slice(0, 10)}</div>
    </footer>
  </div>
  <!-- 森林地面：頁面最底（首頁限定）-->
  <div class="forest-floor" aria-hidden="true">
    <div class="layer trees"></div>
    <div class="layer fore"></div>
  </div>
  <slot name="scripts" />
  <script is:inline src={`${base}js/reveal.js`}></script>
  <script is:inline src="https://unpkg.com/@cobo-screenshot/sdk@1"></script>
  <script is:inline>cobo.init({ workspaceId: "0fb0218a-9bc6-43ef-9916-c6682ebbd64f" })</script>
</body>
</html>
