---
import { pandas, i18n, displayName, zooName } from '../lib/data.js';
import { pandaUrl, pageUrl } from '../lib/links.js';
import { feedbackFormId } from '../lib/feedback.js';

const { locale, slug } = Astro.props;
const T = i18n[locale];
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const p = pandas[slug];

const primary = displayName(p, locale);

// 回報這頁資料有誤：開啟 Tally 表單並用 hidden fields 預填個體身分（panda/slug/url）
const fid = feedbackFormId(locale);
const origin = Astro.site ? Astro.site.origin : '';
const pageHref = origin + pandaUrl(base, locale, p.urlId);
// 內嵌 Tally：hidden fields（panda/slug/url）以 query 帶入，預設收合、點按鈕才載入
const reportEmbedSrc = fid
  ? `https://tally.so/embed/${fid}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&panda=${encodeURIComponent(p.name)}&slug=${encodeURIComponent(p.slug)}&url=${encodeURIComponent(pageHref)}`
  : null;
const altNames = [...new Set([p.name, p.japanese].filter(Boolean).filter((n) => n !== primary))];
const aka = [...(p.nicknames || []), ...(p.english_variants || [])];

// IG 貼文：frontmatter 可寫「URL YYYY-MM-DD」，依貼文日期新到舊排序（無日期者排後）
const igPosts = (p.instagram || []).map((s) => {
  const parts = String(s).trim().split(/\s+/);
  const date = parts[1] && /^\d{4}-\d{2}-\d{2}$/.test(parts[1]) ? parts[1] : '';
  return { url: parts[0], date };
}).sort((a, b) => (b.date || '').localeCompare(a.date || ''));
const IG_PAGE = 6;
const igFirst = igPosts.slice(0, IG_PAGE);
const igRest = igPosts.slice(IG_PAGE);
const igBlock = (url) => `<blockquote class="instagram-media" data-instgrm-permalink="${url}" data-instgrm-version="14" style="margin:0;max-width:540px;width:100%"></blockquote>`;
const sexTxt = p.sex === 'female' ? T.sex_f : p.sex === 'male' ? T.sex_m : T.sex_unknown;

const ageStr = (() => {
  if (!p.born || p.born.length < 10) return '';
  const end = p.died ? new Date(p.died) : new Date();
  const a = Math.floor((end - new Date(p.born)) / 31557600000);
  return a >= 0 ? `（${T.age_years.replace('{n}', a)}）` : '';
})();

const zoosHref = pageUrl(base, locale, 'zoos');
const curZoo = !p.died && (p.current_zoo || p.current_zoo_raw)
  ? (p.current_zoo
      ? `<a class="text-rust hover:underline" href="${zoosHref}#zoo-${p.current_zoo}">${zooName(p.current_zoo, p.current_zoo_raw, locale)}</a>`
      : p.current_zoo_raw)
  : null;

const facts = [
  [T.field_sex, `<span class="inline-block text-[.76rem] px-2 py-px rounded-full ${p.sex === 'female' ? 'bg-[#f7e3df] text-female' : p.sex === 'male' ? 'bg-[#dfeef2] text-male' : 'bg-cream text-rust-dark'}">${sexTxt}</span>`],
  [T.field_born, p.born ? `${p.born} ${ageStr}` : '-'],
  p.died ? [T.field_died, `${p.died} ${T.deceased_mark}`] : null,
  [T.field_species, `<i>${p.species ? 'Ailurus fulgens ' + p.species : '-'}</i>`],
  curZoo ? [T.field_zoo, curZoo] : null,
].filter(Boolean);

const link = (s) => pandas[s]
  ? `<a class="text-rust no-underline hover:underline" href="${pandaUrl(base, locale, pandas[s].urlId)}">${displayName(pandas[s], locale)}${pandas[s].died ? ' 🌈' : ''}</a>` : s;
const famRow = (label, slugs, showCount) => slugs && slugs.length
  ? `<li class="py-1 flex gap-2"><span class="shrink-0 min-w-[9em] text-ink-soft text-[.88rem]">${label}${showCount ? `<span class="ml-1 text-[.82rem]">（${slugs.length}）</span>` : ''}</span><span class="min-w-0 flex-1">${slugs.map(link).join('、')}</span></li>` : '';
// 父母行永遠顯示：缺資料時填「不詳 / Unknown」而非隱藏整行
const parentRow = (label, slug) => slug
  ? famRow(label, [slug])
  : `<li class="py-1 flex gap-2"><span class="shrink-0 min-w-[9em] text-ink-soft text-[.88rem]">${label}</span><span class="min-w-0 flex-1 text-ink-soft">${T.rel_unknown}</span></li>`;

const H3 = 'font-display text-lg font-semibold mt-7 mb-2.5 border-l-4 border-amber pl-2.5';
const CARD = 'card-soft p-[18px_20px]';
const treeBtn = 'pop bg-cream text-rust rounded-full px-3.5 py-1.5 text-[.85rem] border-0 cursor-pointer';
---
<p class="mt-5"><a class="text-rust hover:underline" href={pageUrl(base, locale, 'pandas')}>{T.back_to_search}</a></p>

<!-- 名牌 hero + 基本資料 -->
<div class="card-soft relative overflow-hidden px-5 py-5 mt-2">
  <img src={`${base}img/mascot-peek.webp`} alt="" aria-hidden="true" width="120" height="120"
       class="anim-float pointer-events-none hidden sm:block absolute -right-2 -top-1 w-[84px] h-auto opacity-[.18]" />
  <div class="flex gap-3 items-baseline flex-wrap relative">
    <h1 class="font-display text-3xl font-semibold my-0.5">{primary}{p.died ? ' 🌈' : ''}</h1>
    {altNames.length > 0 && <span class="text-ink-soft text-[1.1rem]">{altNames.join(' · ')}</span>}
  </div>
  {aka.length > 0 && <p class="text-ink-soft text-[.95rem] mt-1 relative">{aka.join('、')}</p>}
  <dl class="grid grid-cols-[auto_1fr] gap-x-[18px] gap-y-1.5 m-0 mt-3 relative">
    {facts.map(([k, v]) => (<><dt class="text-ink-soft text-[.88rem] whitespace-nowrap">{k}</dt><dd class="m-0"><Fragment set:html={v} /></dd></>))}
  </dl>
  {reportEmbedSrc && (
    <div class="mt-3 relative">
      <div class="text-right">
        <button type="button" id="report-toggle" aria-expanded="false" aria-controls="report-panel"
          class="text-ink-soft text-[.82rem] no-underline hover:text-rust hover:underline cursor-pointer bg-transparent border-0 p-0">✏️ {T.report_error}</button>
      </div>
      <div id="report-panel" hidden class="card-soft p-2 sm:p-4 mt-2"></div>
    </div>
  )}
</div>
{reportEmbedSrc && (
  <script is:inline define:vars={{ src: reportEmbedSrc, title: T.report_error }}>
    (function () {
      var btn = document.getElementById('report-toggle');
      var panel = document.getElementById('report-panel');
      if (!btn || !panel) return;
      var loaded = false;
      btn.addEventListener('click', function () {
        if (panel.hasAttribute('hidden')) {
          panel.removeAttribute('hidden');
          btn.setAttribute('aria-expanded', 'true');
          if (!loaded) {
            var f = document.createElement('iframe');
            f.setAttribute('data-tally-src', src);
            f.setAttribute('loading', 'lazy');
            f.width = '100%'; f.height = '420';
            f.frameBorder = '0'; f.marginHeight = '0'; f.marginWidth = '0';
            f.title = title;
            panel.appendChild(f);
            if (window.Tally) {
              window.Tally.loadEmbeds();
            } else {
              var s = document.createElement('script');
              s.src = 'https://tally.so/widgets/embed.js';
              document.body.appendChild(s);
            }
            loaded = true;
          }
        } else {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
)}

{igPosts.length > 0 && (
  <>
    <h2 class={H3}>{T.sec_photos}</h2>
    <div class="grid gap-4 [grid-template-columns:repeat(auto-fill,minmax(300px,1fr))] justify-items-center">
      <Fragment set:html={igFirst.map((p2) => igBlock(p2.url)).join('')} />
      <div id="ig-rest" class="contents"></div>
    </div>
    {igRest.length > 0 && (
      <button id="ig-more" class="pop mt-3 bg-cream text-rust rounded-full px-4 py-2 text-[.9rem] border-0 cursor-pointer">{T.photos_more}（+{igRest.length}）</button>
    )}
    <p class="text-ink-soft text-[.82rem] mt-2">{T.photos_note}</p>
    <script is:inline async src="https://www.instagram.com/embed.js"></script>
    {igRest.length > 0 && (
      <script is:inline define:vars={{ rest: igRest.map((p2) => p2.url) }}>
        document.getElementById('ig-more').addEventListener('click', function () {
          var box = document.getElementById('ig-rest');
          rest.forEach(function (u) {
            var bq = document.createElement('blockquote');
            bq.className = 'instagram-media';
            bq.setAttribute('data-instgrm-permalink', u);
            bq.setAttribute('data-instgrm-version', '14');
            bq.style.cssText = 'margin:0;max-width:540px;width:100%';
            box.appendChild(bq);
          });
          this.remove();
          if (window.instgrm) window.instgrm.Embeds.process();
        });
      </script>
    )}
  </>
)}

{p.residences.length > 0 && (
  <>
    <h2 class={H3}>{T.sec_residences}</h2>
    <div class={`${CARD} reveal`}>
      <table class="w-full text-[.93rem] scroll-x">
        <tr class="text-left text-ink-soft text-[.84rem]"><th class="p-2">{T.th_period}</th><th class="p-2">{T.th_zoo}</th></tr>
        {p.residences.map((r) => (
          <tr class="border-t border-line">
            <td class="p-2 whitespace-nowrap">{r.start || '?'} ~ {r.end || T.present}</td>
            <td class="p-2" set:html={r.zoo_id ? `<a class="text-rust hover:underline" href="${zoosHref}#zoo-${r.zoo_id}">${zooName(r.zoo_id, r.zoo_raw, locale)}</a>` : (r.zoo_raw || '')} />
          </tr>
        ))}
      </table>
    </div>
  </>
)}

<h2 class={H3}>{T.sec_family}</h2>
<div class={`${CARD} reveal`}>
  <ul class="list-none p-0 m-0" set:html={[
    parentRow(T.rel_mother, p.mother),
    parentRow(T.rel_father, p.father),
    famRow(
      (p.twins || []).length === 2 ? (T.rel_triplet || T.rel_twin)
      : (p.twins || []).length >= 3 ? (T.rel_quadruplet || T.rel_triplet || T.rel_twin)
      : T.rel_twin,
      p.twins),
    famRow(T.rel_siblings, p.full_siblings, true),
    famRow(T.rel_half_siblings, p.half_siblings, true),
  ].join('')} />
  {p.children.length > 0 && (
    <>
      <h3 class="font-display text-base mt-4 mb-2 font-semibold">{T.sec_children}</h3>
      <table class="w-full text-[.93rem] scroll-x">
        <tr class="text-left text-ink-soft text-[.84rem]"><th class="p-2">{T.th_name}</th><th class="p-2">{T.th_born_year}</th><th class="p-2">{T.th_other_parent}</th></tr>
        {p.children.map((c) => {
          const q = pandas[c];
          const other = [q.mother, q.father].filter((s) => s && s !== p.slug)[0];
          return (
            <tr class="border-t border-line">
              <td class="p-2" set:html={link(c)} />
              <td class="p-2">{(q.born || '?').slice(0, 4)}</td>
              <td class="p-2" set:html={other ? link(other) : '-'} />
            </tr>
          );
        })}
      </table>
    </>
  )}
</div>

<>
    <h2 class={H3}>{T.sec_tree}</h2>
    <div class={`${CARD} reveal`}>
      <div class="flex gap-2 items-center flex-wrap mb-2.5">
        <button class={treeBtn} id="tree-up">{T.tree_more_ancestors}</button>
        <button class={treeBtn} id="tree-down">{T.tree_more_descendants}</button>
        <button class={treeBtn} id="tree-half" style="display:none">{T.tree_show_half}</button>
        <span class="inline-flex gap-1.5 ml-auto">
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-zoom-out" aria-label="zoom out">−</button>
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-zoom-in" aria-label="zoom in">＋</button>
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-reset" aria-label="reset">⟳</button>
        </span>
      </div>
      <div id="tree-box" data-slug={slug}></div>
      <p class="text-[.82rem] text-ink-soft mt-2">{T.tree_hint}</p>
    </div>
</>
