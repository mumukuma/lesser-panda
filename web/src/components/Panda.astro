---
import { pandas, i18n, displayName, zooName } from '../lib/data.js';
import { pandaUrl, pageUrl } from '../lib/links.js';
import { feedbackFormId, photoFormId } from '../lib/feedback.js';

const { locale, slug } = Astro.props;
const T = i18n[locale];
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const p = pandas[slug];

const primary = displayName(p, locale);

// 回報這頁資料有誤：開啟 Tally 表單並用 hidden fields 預填個體身分（panda/slug/url）
const fid = feedbackFormId(locale);
const origin = Astro.site ? Astro.site.origin : '';
const pageHref = origin + pandaUrl(base, locale, p.urlId);
// 內嵌 Tally：hidden fields（panda/slug/url）以 query 帶入，預設收合、點按鈕才載入
const reportEmbedSrc = fid
  ? `https://tally.so/embed/${fid}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&panda=${encodeURIComponent(p.name)}&slug=${encodeURIComponent(p.slug)}&url=${encodeURIComponent(pageHref)}`
  : null;
// 照片投稿：同款 hidden fields（panda/slug/url）帶入身分；表單 ID 未設時為 null → CTA 不渲染
const pfid = photoFormId(locale);
const photoEmbedSrc = pfid
  ? `https://tally.so/embed/${pfid}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&panda=${encodeURIComponent(p.name)}&slug=${encodeURIComponent(p.slug)}&url=${encodeURIComponent(pageHref)}`
  : null;
const altNames = [...new Set([p.name, p.japanese].filter(Boolean).filter((n) => n !== primary))];
const aka = [...(p.nicknames || []), ...(p.english_variants || [])];

// IG 貼文：frontmatter 可寫「URL YYYY-MM-DD」，依貼文日期新到舊排序（無日期者排後）
const igPosts = (p.instagram || []).map((s) => {
  const parts = String(s).trim().split(/\s+/);
  const date = parts[1] && /^\d{4}-\d{2}-\d{2}$/.test(parts[1]) ? parts[1] : '';
  const url = parts[0];
  // 含帳號的完整形式 instagram.com/帳號/p/XXX/ 可解析出發文帳號作署名；僅 /p/XXX/ 則無
  const am = url.match(/instagram\.com\/([^/?#]+)\/(?:p|reel|tv)\//i);
  const account = am ? am[1] : '';
  // embed.js 只認標準 /p|reel|tv/SHORTCODE/，含帳號的形式會載不出來 → 餵 embed 用正規化的 permalink
  const sm = url.match(/instagram\.com\/(?:[^/?#]+\/)?(p|reel|tv)\/([^/?#]+)/i);
  const embedUrl = sm ? `https://www.instagram.com/${sm[1]}/${sm[2]}/` : url;
  return { url, date, account, embedUrl };
}).sort((a, b) => (b.date || '').localeCompare(a.date || ''));
const IG_PAGE = 6;
const igRest = igPosts.slice(IG_PAGE);
const sexTxt = p.sex === 'female' ? T.sex_f : p.sex === 'male' ? T.sex_m : T.sex_unknown;

const ageStr = (() => {
  if (!p.born || p.born.length < 10) return '';
  const end = p.died ? new Date(p.died) : new Date();
  const a = Math.floor((end - new Date(p.born)) / 31557600000);
  return a >= 0 ? `（${T.age_years.replace('{n}', a)}）` : '';
})();

const zoosHref = pageUrl(base, locale, 'zoos');
const curZoo = !p.died && (p.current_zoo || p.current_zoo_raw)
  ? (p.current_zoo
      ? `<a class="text-rust hover:underline" href="${zoosHref}#zoo-${p.current_zoo}">${zooName(p.current_zoo, p.current_zoo_raw, locale)}</a>`
      : p.current_zoo_raw)
  : null;

const facts = [
  [T.field_sex, `<span class="inline-block text-[.76rem] px-2 py-px rounded-full ${p.sex === 'female' ? 'bg-[#f7e3df] text-female' : p.sex === 'male' ? 'bg-[#dfeef2] text-male' : 'bg-cream text-rust-dark'}">${sexTxt}</span>`],
  [T.field_born, p.born ? `${p.born} ${ageStr}` : '-'],
  p.died ? [T.field_died, `${p.died} ${T.deceased_mark}`] : null,
  [T.field_species, `<i>${p.species ? 'Ailurus fulgens ' + p.species : '-'}</i>`],
  curZoo ? [T.field_zoo, curZoo] : null,
].filter(Boolean);

const link = (s) => pandas[s]
  ? `<a class="text-rust no-underline hover:underline" href="${pandaUrl(base, locale, pandas[s].urlId)}">${displayName(pandas[s], locale)}${pandas[s].died ? ' 🌈' : ''}</a>` : s;
const famRow = (label, slugs, showCount) => slugs && slugs.length
  ? `<li class="py-1 flex flex-col sm:flex-row sm:gap-2"><span class="sm:shrink-0 sm:min-w-[9em] text-ink-soft text-[.88rem]">${label}${showCount ? `<span class="ml-1 text-[.82rem]">（${slugs.length}）</span>` : ''}</span><span class="min-w-0 flex-1">${slugs.map(link).join('、')}</span></li>` : '';
// 父母行永遠顯示：缺資料時填「不詳 / Unknown」而非隱藏整行
const parentRow = (label, slug) => slug
  ? famRow(label, [slug])
  : `<li class="py-1 flex flex-col sm:flex-row sm:gap-2"><span class="sm:shrink-0 sm:min-w-[9em] text-ink-soft text-[.88rem]">${label}</span><span class="min-w-0 flex-1 text-ink-soft">${T.rel_unknown}</span></li>`;

const H3 = 'font-display text-lg font-semibold mt-7 mb-2.5 border-l-4 border-amber pl-2.5';
const CARD = 'card-soft p-[18px_20px]';
const treeBtn = 'pop bg-cream text-rust rounded-full px-3.5 py-1.5 text-[.85rem] border-0 cursor-pointer';
---
<p class="mt-5"><a class="text-rust hover:underline" href={pageUrl(base, locale, 'pandas')}>{T.back_to_search}</a></p>

<!-- 名牌 hero + 基本資料 -->
<div class="card-soft relative overflow-hidden px-5 py-5 mt-2">
  <img src={`${base}img/mascot-peek.webp`} alt="" aria-hidden="true" width="120" height="120"
       class="anim-float pointer-events-none hidden sm:block absolute -right-2 -top-1 w-[84px] h-auto opacity-[.18]" />
  <div class="flex gap-3 items-baseline flex-wrap relative">
    <h1 class="font-display text-3xl font-semibold my-0.5">{primary}{p.died ? ' 🌈' : ''}</h1>
    {altNames.length > 0 && <span class="text-ink-soft text-[1.1rem]">{altNames.join(' · ')}</span>}
  </div>
  {aka.length > 0 && <p class="text-ink-soft text-[.95rem] mt-1 relative">{aka.join('、')}</p>}
  {igPosts.length > 0 && (
    <a href="#photos" class="pop no-underline inline-flex items-center gap-1.5 bg-cream text-rust rounded-full px-3 py-1 text-[.82rem] font-medium mt-2.5 relative"
       aria-label={`${igPosts.length} ${T.sec_photos}`}>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.2"/></svg>
      {igPosts.length}<span class="font-normal">{T.sec_photos}</span>
    </a>
  )}
  <dl class="grid grid-cols-[auto_1fr] gap-x-[18px] gap-y-1.5 m-0 mt-3 relative">
    {facts.map(([k, v]) => (<><dt class="text-ink-soft text-[.88rem] whitespace-nowrap">{k}</dt><dd class="m-0"><Fragment set:html={v} /></dd></>))}
  </dl>
  {reportEmbedSrc && (
    <div class="mt-3 relative">
      <div class="text-right">
        <button type="button" id="report-toggle" aria-expanded="false" aria-controls="report-panel"
          class="text-ink-soft text-[.82rem] no-underline hover:text-rust hover:underline cursor-pointer bg-transparent border-0 p-0">✏️ {T.report_error}</button>
      </div>
      <div id="report-panel" hidden class="card-soft p-2 sm:p-4 mt-2"></div>
    </div>
  )}
</div>
{reportEmbedSrc && (
  <script is:inline define:vars={{ src: reportEmbedSrc, title: T.report_error }}>
    (function () {
      var btn = document.getElementById('report-toggle');
      var panel = document.getElementById('report-panel');
      if (!btn || !panel) return;
      var loaded = false;
      btn.addEventListener('click', function () {
        if (panel.hasAttribute('hidden')) {
          panel.removeAttribute('hidden');
          btn.setAttribute('aria-expanded', 'true');
          if (!loaded) {
            var f = document.createElement('iframe');
            f.setAttribute('data-tally-src', src);
            f.setAttribute('loading', 'lazy');
            f.width = '100%'; f.height = '420';
            f.frameBorder = '0'; f.marginHeight = '0'; f.marginWidth = '0';
            f.title = title;
            panel.appendChild(f);
            if (window.Tally) {
              window.Tally.loadEmbeds();
            } else {
              var s = document.createElement('script');
              s.src = 'https://tally.so/widgets/embed.js';
              document.body.appendChild(s);
            }
            loaded = true;
          }
        } else {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
)}

{p.residences.length > 0 && (
  <>
    <h2 class={H3}>{T.sec_residences}</h2>
    <div class={`${CARD} reveal`}>
      <table class="w-full text-[.93rem] scroll-x">
        <tr class="text-left text-ink-soft text-[.84rem]"><th class="p-2">{T.th_period}</th><th class="p-2">{T.th_zoo}</th></tr>
        {[...p.residences].reverse().map((r) => (
          <tr class="border-t border-line">
            <td class="p-2 whitespace-nowrap">{r.start || '?'} ~ {r.end || T.present}</td>
            <td class="p-2" set:html={r.zoo_id ? `<a class="text-rust hover:underline" href="${zoosHref}#zoo-${r.zoo_id}">${zooName(r.zoo_id, r.zoo_raw, locale)}</a>` : (r.zoo_raw || '')} />
          </tr>
        ))}
      </table>
    </div>
  </>
)}

<h2 class={H3}>{T.sec_family}</h2>
<div class={`${CARD} reveal`}>
  <ul class="list-none p-0 m-0" set:html={[
    parentRow(T.rel_mother, p.mother),
    parentRow(T.rel_father, p.father),
    famRow(
      (p.twins || []).length === 2 ? (T.rel_triplet || T.rel_twin)
      : (p.twins || []).length >= 3 ? (T.rel_quadruplet || T.rel_triplet || T.rel_twin)
      : T.rel_twin,
      p.twins),
    famRow(T.rel_siblings, p.full_siblings, true),
    famRow(T.rel_half_siblings, p.half_siblings, true),
  ].join('')} />
  {p.children.length > 0 && (
    <>
      <h3 class="font-display text-base mt-4 mb-2 font-semibold">{T.sec_children}</h3>
      <table class="w-full text-[.93rem] scroll-x">
        <tr class="text-left text-ink-soft text-[.84rem]"><th class="p-2">{T.th_name}</th><th class="p-2">{T.th_born_year}</th><th class="p-2">{T.th_other_parent}</th></tr>
        {p.children.map((c) => {
          const q = pandas[c];
          const other = [q.mother, q.father].filter((s) => s && s !== p.slug)[0];
          return (
            <tr class="border-t border-line">
              <td class="p-2" set:html={link(c)} />
              <td class="p-2">{(q.born || '?').slice(0, 4)}</td>
              <td class="p-2" set:html={other ? link(other) : '-'} />
            </tr>
          );
        })}
      </table>
    </>
  )}
</div>

<>
    <h2 class={H3}>{T.sec_tree}</h2>
    <div class={`${CARD} reveal`}>
      <div class="flex gap-2 items-center flex-wrap mb-2.5">
        <button class={treeBtn} id="tree-up">{T.tree_more_ancestors}</button>
        <button class={treeBtn} id="tree-down">{T.tree_more_descendants}</button>
        <button class={treeBtn} id="tree-half" style="display:none">{T.tree_show_half}</button>
        <span class="inline-flex gap-1.5 ml-auto">
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-zoom-out" aria-label="zoom out">−</button>
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-zoom-in" aria-label="zoom in">＋</button>
          <button class="pop bg-cream text-rust rounded-full px-3 py-1.5 text-base leading-none border-0 cursor-pointer min-w-[38px]" id="tree-reset" aria-label="reset">⟳</button>
        </span>
      </div>
      <div id="tree-box" data-slug={slug}></div>
      <p class="text-[.82rem] text-ink-soft mt-2">{T.tree_hint}</p>
    </div>
</>

{igPosts.length > 0 && (
  <>
    <h2 id="photos" class={`${H3} scroll-mt-20`}>{T.sec_photos}<span class="ml-1.5 text-ink-soft text-[.8rem] font-normal align-middle">（{igPosts.length}）</span></h2>
    {/* 方案 C：facade ＋ lazy-load。開頁只有零 iframe 的骨架卡（脈動載入動畫），捲進視窗附近才換成真 IG embed；embed 載好後骨架才移除。 */}
    {/* 瀑布流：CSS columns 讓不同高度的卡片往上補、不留整列空白（桌機依寬度自動 2+ 欄、手機 1 欄）。 */}
    <div id="ig-grid" class="columns-[340px] [column-gap:1rem]">
      {igPosts.map((p2, i) => (
        <div class="ig-item mb-4 break-inside-avoid" hidden={i >= IG_PAGE}>
          <div class="ig-slot relative w-full min-h-[320px]" data-permalink={p2.embedUrl}>
            <a href={p2.url} target="_blank" rel="noopener"
               class="ig-skeleton card-soft no-underline absolute inset-0 z-10 animate-pulse flex flex-col items-center justify-center gap-2 text-ink-soft">
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="opacity-50">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <circle cx="8.5" cy="8.5" r="1.6" />
                <path d="M21 15l-5-5L5 21" />
              </svg>
              <span class="text-[.9rem] font-medium">{p2.account ? '@' + p2.account : 'Instagram'}</span>
              {p2.date && <span class="text-[.75rem] opacity-70">{p2.date}</span>}
              <span class="text-[.72rem] opacity-60">{T.photos_loading}</span>
            </a>
          </div>
        </div>
      ))}
    </div>
    {igRest.length > 0 && (
      <button id="ig-more" class="pop mt-3 bg-cream text-rust rounded-full px-4 py-2 text-[.9rem] border-0 cursor-pointer">{T.photos_more}（+{igRest.length}）</button>
    )}
    <p class="text-ink-soft text-[.82rem] mt-2">{T.photos_note}</p>
    <script is:inline define:vars={{ PAGE: IG_PAGE, PIN: 1 }}>
      (function () {
        var grid = document.getElementById('ig-grid');
        if (!grid) return;

        // 混合隨機：釘最新 PIN 張，其餘每次造訪洗牌（Fisher–Yates）。只洗佔位卡順序，
        // lazy-load 不變、不重建 iframe；洗前隱藏 grid 避免重排閃動。
        (function shuffleRest() {
          var items = Array.prototype.slice.call(grid.querySelectorAll('.ig-item'));
          if (items.length <= PIN + 1) return; // 沒得洗就跳過
          grid.style.visibility = 'hidden';
          var rest = items.slice(PIN);
          for (var i = rest.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var t = rest[i]; rest[i] = rest[j]; rest[j] = t;
          }
          rest.forEach(function (el) { grid.appendChild(el); }); // 依洗後順序重排（釘住的留在前）
          grid.querySelectorAll('.ig-item').forEach(function (el, idx) {
            if (idx < PAGE) el.removeAttribute('hidden'); // 前 PAGE 張顯示
            else el.setAttribute('hidden', '');           // 其餘收進「顯示更多」
          });
          grid.style.visibility = '';
        })();

        // IG embed 修正：IG 在 embed 載入時用「當下寬度」把 iframe 高度寫死，之後只在 window resize 才重算。
        // 兩欄 grid + lazy-load 下，定高時的寬度可能與最終卡片寬度對不上 → 圖片被壓扁。
        // 對策：embed 載好、顯示更多、或 grid 寬度變動時，觸發一次 resize 讓 IG 依現寬重新 fit。
        var refitTimer;
        function refit() {
          clearTimeout(refitTimer);
          refitTimer = setTimeout(function () {
            try { window.dispatchEvent(new Event('resize')); } catch (e) {}
          }, 150);
        }
        var lastW = grid.clientWidth;
        if ('ResizeObserver' in window) {
          new ResizeObserver(function () {
            var w = grid.clientWidth;
            if (w !== lastW) { lastW = w; refit(); } // 只在寬度變動時 refit（高度變動不理，避免迴圈）
          }).observe(grid);
        }

        // embed.js 延後到第一張卡要載入時才注入（開頁零成本）
        var scriptState = 0; // 0=未載 1=載入中 2=就緒
        var pending = [];
        function ensureScript(cb) {
          if (scriptState === 2) return cb();
          pending.push(cb);
          if (scriptState === 1) return;
          scriptState = 1;
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.instagram.com/embed.js';
          s.onload = function () {
            scriptState = 2;
            pending.forEach(function (f) { f(); });
            pending = [];
          };
          document.body.appendChild(s);
        }

        function load(slot) {
          if (slot.dataset.loaded) return;
          slot.dataset.loaded = '1';
          var url = slot.getAttribute('data-permalink');
          var bq = document.createElement('blockquote');
          bq.className = 'instagram-media';
          bq.setAttribute('data-instgrm-permalink', url);
          bq.setAttribute('data-instgrm-version', '14');
          bq.style.cssText = 'margin:0;max-width:540px;width:100%';
          slot.appendChild(bq); // 骨架卡（absolute 覆蓋）留著當載入動畫，embed 在底下載入
          ensureScript(function () {
            if (window.instgrm) window.instgrm.Embeds.process();
            // embed 成功後 IG 會在 blockquote 內塞 iframe → 移除骨架、露出照片。
            // 讀者層失效處理：等不到 iframe 就保守隱藏整個 slot，避免破版空白。
            // （已刪/轉私密的貼文 IG 仍會給一張錯誤 iframe，此啟發式抓不到，交由作者層 audit 處理）
            var waited = 0;
            var timer = setInterval(function () {
              waited += 400;
              if (slot.querySelector('iframe')) {
                clearInterval(timer);
                var sk = slot.querySelector('.ig-skeleton');
                if (sk) sk.remove();
                slot.style.minHeight = '0';
                refit(); // embed 剛出現，逼 IG 依卡片現寬重算高度，避免比例被壓扁
              } else if (waited >= 8000) {
                clearInterval(timer);
                slot.style.display = 'none';
              }
            }, 400);
          });
        }

        var io = 'IntersectionObserver' in window
          ? new IntersectionObserver(function (entries, obs) {
              entries.forEach(function (e) {
                if (e.isIntersecting) { obs.unobserve(e.target); load(e.target); }
              });
            }, { rootMargin: '400px 0px' })
          : null;

        function observe(slot) {
          if (io) io.observe(slot);
          else load(slot); // 無 IntersectionObserver 的舊瀏覽器：直接載入
        }

        grid.querySelectorAll('.ig-item:not([hidden]) .ig-slot').forEach(observe);

        var moreBtn = document.getElementById('ig-more');
        if (moreBtn) {
          moreBtn.addEventListener('click', function () {
            grid.querySelectorAll('.ig-item[hidden]').forEach(function (item) {
              item.removeAttribute('hidden');
              var slot = item.querySelector('.ig-slot');
              if (slot) observe(slot); // 顯示更多只是亮出骨架卡，載入仍交給 lazy-load
            });
            refit(); // 新卡展開後版面寬度可能變（如出現捲軸），讓已載入的 embed 重新 fit
            this.remove();
          });
        }
      })();
    </script>
  </>
)}

{/* 投稿 CTA：一律顯示（零照片的個體最需要投稿）。點按鈕才載入 Tally embed，panda/slug/url 預填。 */}
{photoEmbedSrc && (
  <>
    {igPosts.length === 0 && <h2 class={H3}>{T.sec_photos}</h2>}
    <div class="card-soft p-4 mt-3 text-center reveal">
      <p class="m-0 text-[.95rem] text-ink-soft" set:html={T.photos_cta.replace('{name}', `<span class="text-rust font-medium">${primary}</span>`)} />
      <button type="button" id="photo-toggle" aria-expanded="false" aria-controls="photo-panel"
        class="pop mt-2.5 bg-rust text-white rounded-full px-4 py-2 text-[.9rem] border-0 cursor-pointer">📷 {T.photos_cta_btn}</button>
      <div id="photo-panel" hidden class="mt-3 text-left"></div>
    </div>
    <script is:inline define:vars={{ src: photoEmbedSrc, title: T.photos_cta_btn }}>
      (function () {
        var btn = document.getElementById('photo-toggle');
        var panel = document.getElementById('photo-panel');
        if (!btn || !panel) return;
        var loaded = false;
        btn.addEventListener('click', function () {
          if (panel.hasAttribute('hidden')) {
            panel.removeAttribute('hidden');
            btn.setAttribute('aria-expanded', 'true');
            if (!loaded) {
              var f = document.createElement('iframe');
              f.setAttribute('data-tally-src', src);
              f.setAttribute('loading', 'lazy');
              f.width = '100%'; f.height = '500';
              f.frameBorder = '0'; f.marginHeight = '0'; f.marginWidth = '0';
              f.title = title;
              panel.appendChild(f);
              if (window.Tally) {
                window.Tally.loadEmbeds();
              } else {
                var s = document.createElement('script');
                s.src = 'https://tally.so/widgets/embed.js';
                document.body.appendChild(s);
              }
              loaded = true;
            }
          } else {
            panel.setAttribute('hidden', '');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      })();
    </script>
  </>
)}
