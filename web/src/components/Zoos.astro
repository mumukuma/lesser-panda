---
import { zoos, pandas, i18n, displayName, zooName } from '../lib/data.js';
import { pandaUrl } from '../lib/links.js';
const { locale } = Astro.props;
const T = i18n[locale];
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const resLink = (s) =>
  pandas[s] ? `<a class="text-rust no-underline hover:underline" href="${pandaUrl(base, locale, pandas[s].urlId)}">${displayName(pandas[s], locale)}${pandas[s].died ? ' 🌈' : ''}</a>` : s;
---
<h1 class="text-2xl font-bold mt-7 mb-1.5">{T.nav_zoos}</h1>
<p class="text-ink-soft mb-4">{T.zoos_intro}</p>
<div id="map"><p class="p-5 text-ink-soft">Loading map…</p></div>

<div class="grid gap-3.5 mt-4.5 [grid-template-columns:repeat(auto-fill,minmax(280px,1fr))]">
  {zoos.map((z, i) => (
    <div class="bg-card border border-line rounded-card shadow-card p-[18px_20px]" id={`zoo-${z.id}`}>
      <h3 class="m-0 mb-1 text-[1.02rem] flex items-start gap-2.5 leading-snug">
        {z.logo && <img class="w-[26px] h-[26px] flex-none mt-px object-contain bg-white border border-line rounded-md p-0.5" src={z.logo} alt="" loading="lazy" onerror="this.style.display='none'" />}
        {zooName(z.id, z.en_name, locale)}
      </h3>
      <div class="text-[.84rem] text-ink-soft mb-2">{z.location_ja || z.location_en || z.country || ''}</div>
      <div class="text-[.9rem]">
        <strong>{T.zoo_residents}（{z.residents.length}）</strong><br />
        <Fragment set:html={z.residents.map(resLink).join('、') || T.zoo_no_residents} />
      </div>
      <div class="mt-2.5 flex gap-2 flex-wrap">
        {z.lat && <button class="bg-cream text-rust rounded-full px-3.5 py-1.5 text-[.85rem] border-0 cursor-pointer" data-zoo-focus={z.id}>📍</button>}
        {z.lat && <a class="bg-rust text-white rounded-full px-3.5 py-1.5 text-[.85rem] no-underline hover:bg-rust-dark" target="_blank" rel="noopener" href={`https://www.google.com/maps/dir/?api=1&destination=${z.lat},${z.lng}`}>{T.zoo_directions}</a>}
        {z.website && <a class="bg-cream text-rust rounded-full px-3.5 py-1.5 text-[.85rem] no-underline" target="_blank" rel="noopener" href={z.website}>{T.zoo_website}</a>}
      </div>
    </div>
  ))}
</div>
