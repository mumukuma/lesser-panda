---
import { i18n } from '../lib/data.js';
const { locale } = Astro.props;
const T = i18n[locale];
const inputCls = 'bg-card text-ink border border-line rounded-[10px] px-3.5 py-2.5 font-[inherit]';
---
<h1 class="text-2xl font-bold mt-7 mb-1.5">{T.nav_search}</h1>
<div class="flex gap-2.5 flex-wrap items-center my-4">
  <input type="search" id="f-q" placeholder={T.search_placeholder} class={`flex-1 min-w-[240px] ${inputCls}`} />
  <select id="f-zoo" class={inputCls}><option value="">{T.filter_zoo}：{T.filter_all}</option></select>
  <select id="f-sex" class={inputCls}>
    <option value="">{T.filter_sex}：{T.filter_all}</option>
    <option value="female">{T.filter_female}</option>
    <option value="male">{T.filter_male}</option>
  </select>
  <label class="text-[.9rem] text-ink-soft flex gap-1.5 items-center"><input type="checkbox" id="f-alive" />{T.filter_alive_only}</label>
</div>
<p id="result-count" class="text-ink-soft text-[.88rem] mb-2.5"></p>
<div class="grid gap-3.5 [grid-template-columns:repeat(auto-fill,minmax(230px,1fr))]" id="results"></div>
