---
import Layout from '../layouts/Layout.astro';
import { pageUrl } from '../lib/links.js';

// 靜態站：GitHub Pages 會以 dist/404.html 服務所有找不到的網址。
// 預設語系 zh-TW；訊息三語並陳，任何語系迷路的訪客都看得懂。
const locale = 'zh-TW';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const homeUrl = base;
const searchUrl = pageUrl(base, locale, 'search');
---
<Layout locale={locale} relPath="" active="" title="404">
  <section class="text-center py-12 sm:py-16">
    <img src={`${base}img/mascot-peek.webp`} alt="" width="120" height="120"
         class="anim-float w-20 h-20 sm:w-24 sm:h-24 mx-auto mb-2 object-contain" />
    <div class="font-display text-6xl sm:text-7xl font-semibold text-rust leading-none">404</div>
    <h1 class="font-display text-xl sm:text-2xl font-semibold text-rust-dark mt-3 mb-1">找不到這隻小熊貓</h1>
    <p class="text-ink-soft leading-relaxed max-w-md mx-auto">
      這個網址可能已更新或不存在。
      <br class="hidden sm:block" />このページは見つかりませんでした。・This page could not be found.
    </p>
    <div class="flex flex-wrap gap-2.5 items-center justify-center mt-6">
      <a href={homeUrl}
         class="pop bg-rust text-white rounded-full px-5 py-2.5 text-[.92rem] font-semibold no-underline hover:bg-rust-dark">🏠 回首頁</a>
      <a href={searchUrl}
         class="pop bg-cream border border-line rounded-full px-5 py-2.5 text-[.92rem] font-semibold no-underline hover:border-amber">🔍 圖鑑搜尋</a>
    </div>
  </section>
</Layout>
