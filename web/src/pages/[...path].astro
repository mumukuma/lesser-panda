---
import Layout from '../layouts/Layout.astro';
import Home from '../components/Home.astro';
import Search from '../components/Search.astro';
import Zoos from '../components/Zoos.astro';
import Panda from '../components/Panda.astro';
import Feedback from '../components/Feedback.astro';
import Thanks from '../components/Thanks.astro';
import { pandas, zoos, LOCALES, searchDataFor, subGraph, displayName } from '../lib/data.js';

export function getStaticPaths() {
  const out = [];
  for (const l of LOCALES) {
    const path = (sub) => (l.dir + sub).replace(/\/$/, '');
    out.push({ params: { path: path('') || undefined }, props: { locale: l.code, kind: 'home', relPath: '' } });
    out.push({ params: { path: path('pandas') }, props: { locale: l.code, kind: 'pandas', relPath: 'pandas' } });
    out.push({ params: { path: path('zoos') }, props: { locale: l.code, kind: 'zoos', relPath: 'zoos' } });
    out.push({ params: { path: path('feedback') }, props: { locale: l.code, kind: 'feedback', relPath: 'feedback' } });
    out.push({ params: { path: path('thanks') }, props: { locale: l.code, kind: 'thanks', relPath: 'thanks' } });
    for (const p of Object.values(pandas)) {
      out.push({ params: { path: path('p/' + p.urlId) }, props: { locale: l.code, kind: 'panda', slug: p.slug, relPath: 'p/' + p.urlId } });
    }
  }
  return out;
}

const { locale, kind, slug, relPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const titles = {
  home: undefined,
  pandas: (await import('../lib/data.js')).i18n[locale].nav_search,
  zoos: (await import('../lib/data.js')).i18n[locale].nav_zoos,
  feedback: (await import('../lib/data.js')).i18n[locale].nav_feedback,
  thanks: (await import('../lib/data.js')).i18n[locale].thanks_title,
  panda: kind === 'panda' ? displayName(pandas[slug], locale) : undefined,
};
const active = kind === 'home' ? 'home' : kind;

const p = kind === 'panda' ? pandas[slug] : null;
const graph = p ? subGraph(slug) : null;
---
<Layout locale={locale} relPath={relPath} active={active} title={titles[kind]}>
  {kind === 'zoos' && <link slot="head" rel="stylesheet" href={`${base}vendor/leaflet.css`} />}

  {kind === 'home' && <Home locale={locale} />}
  {kind === 'pandas' && <Search locale={locale} />}
  {kind === 'zoos' && <Zoos locale={locale} />}
  {kind === 'feedback' && <Feedback locale={locale} />}
  {kind === 'thanks' && <Thanks locale={locale} />}
  {kind === 'panda' && <Panda locale={locale} slug={slug} />}

  {kind === 'home' && (
    <Fragment slot="scripts">
      <script is:inline define:vars={{ data: searchDataFor(locale) }}>window.TODAY_DATA = data;</script>
      <script is:inline src={`${base}js/today.js`}></script>
    </Fragment>
  )}
  {kind === 'pandas' && (
    <Fragment slot="scripts">
      <script is:inline define:vars={{ data: searchDataFor(locale) }}>window.SEARCH_DATA = data;</script>
      <script is:inline src={`${base}js/search.js`}></script>
    </Fragment>
  )}
  {kind === 'zoos' && (
    <Fragment slot="scripts">
      <script is:inline define:vars={{ data: { zoos } }}>window.ZOOS_DATA = data;</script>
      <script is:inline src={`${base}vendor/leaflet.js`}></script>
      <script is:inline src={`${base}js/map.js`}></script>
      <script is:inline src={`${base}js/zoos.js`}></script>
    </Fragment>
  )}
  {kind === 'feedback' && (
    <Fragment slot="scripts">
      <script is:inline async src="https://tally.so/widgets/embed.js"></script>
    </Fragment>
  )}
  {kind === 'panda' && graph && (
    <Fragment slot="scripts">
      <script is:inline define:vars={{ data: graph }}>window.GRAPH_DATA = data;</script>
      <script is:inline src={`${base}js/tree.js`}></script>
    </Fragment>
  )}
</Layout>
