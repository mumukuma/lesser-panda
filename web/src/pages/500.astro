---
import Layout from '../layouts/Layout.astro';
import { pageUrl } from '../lib/links.js';

// 一般錯誤頁（伺服器／執行錯誤）。靜態站平常不會觸發，保留作為通用錯誤畫面。
const locale = 'zh-TW';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const homeUrl = base;
const searchUrl = pageUrl(base, locale, 'pandas');
---
<Layout locale={locale} relPath="" active="" title="500">
  <section class="text-center py-12 sm:py-16">
    <img src={`${base}img/mascot-peek.webp`} alt="" width="120" height="120"
         class="anim-float w-20 h-20 sm:w-24 sm:h-24 mx-auto mb-2 object-contain" />
    <div class="font-display text-6xl sm:text-7xl font-semibold text-rust leading-none">500</div>
    <h1 class="font-display text-xl sm:text-2xl font-semibold text-rust-dark mt-3 mb-1">小熊貓打翻了竹子</h1>
    <p class="text-ink-soft leading-relaxed max-w-md mx-auto">
      網站出了點問題，請稍後再試一次。
      <br class="hidden sm:block" />問題が発生しました。しばらくして再度お試しください。・Something went wrong — please try again later.
    </p>
    <div class="flex flex-wrap gap-2.5 items-center justify-center mt-6">
      <a href={homeUrl}
         class="pop bg-rust text-white rounded-full px-5 py-2.5 text-[.92rem] font-semibold no-underline hover:bg-rust-dark">🏠 回首頁</a>
      <a href={searchUrl}
         class="pop bg-cream border border-line rounded-full px-5 py-2.5 text-[.92rem] font-semibold no-underline hover:border-amber">🔍 圖鑑搜尋</a>
    </div>
  </section>
</Layout>
